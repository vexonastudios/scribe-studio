{
  "name": "scribe-studio",
  "version": "1.0.5",
  "description": "Scribe Studio — local AI audiobook transcription and YouTube caption converter by Vexona Studios.",
  "author": "Vexona Studios",
  "main": "dist/main/main.js",
  "private": true,
  "scripts": {
    "dev": "concurrently --kill-others-on-fail \"vite --host 127.0.0.1\" \"tsc -p tsconfig.node.json --watch\" \"wait-on --timeout 60000 dist/main/main.js http://127.0.0.1:5173 && electron .\"",
    "build": "tsc -p tsconfig.node.json && tsc -p tsconfig.json && vite build",
    "start": "electron .",
    "typecheck": "tsc -p tsconfig.node.json && tsc -p tsconfig.json --noEmit",
    "dist:win": "npm run build && electron-builder --win --x64",
    "dist:publish": "npm run build && electron-builder --win --x64 --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^8.2.2",
    "electron": "^31.1.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.5.3",
    "vite": "^5.3.3",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.vexonastudios.scribe-studio",
    "productName": "Scribe Studio",
    "copyright": "Copyright © 2025 Vexona Studios",
    "asar": true,
    "files": [
      "dist/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "engine",
        "to": "engine",
        "filter": [
          "**/*",
          "!__pycache__/**",
          "!*.pyc"
        ]
      },
      {
        "from": "scripts",
        "to": "scripts"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Scribe Studio",
      "include": "build/installer.nsh"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "vexonastudios",
        "repo": "scribe-studio",
        "releaseType": "release"
      }
    ],
    "directories": {
      "buildResources": "assets",
      "output": "release"
    }
  }
}
