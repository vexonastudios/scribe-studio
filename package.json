{
  "name": "sbv-vtt-converter",
  "version": "0.1.0",
  "description": "Local Electron app for batch converting YouTube SBV caption files to WebVTT.",
  "main": "dist/main/main.js",
  "private": true,
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"tsc -p tsconfig.node.json --watch\" \"wait-on dist/main/main.js tcp:5173 && electron .\"",
    "build": "tsc -p tsconfig.node.json && tsc -p tsconfig.json && vite build",
    "start": "electron .",
    "typecheck": "tsc -p tsconfig.node.json && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "electron": "^31.1.0",
    "typescript": "^5.5.3",
    "vite": "^5.3.3",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "local.sbv-vtt-converter",
    "productName": "SBV to VTT Converter",
    "files": [
      "dist/**",
      "package.json"
    ]
  }
}
